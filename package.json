{
  "name": "projectmanager",
  "private": true,
  "version": "1.0.0",
  "description": "ProjectManager — Turborepo monorepo: web (React), API (Express), mobile (Expo), and shared packages.",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:api": "pnpm --filter @pm/api dev",
    "dev:web": "pnpm --filter @pm/web dev",
    "dev:mobile": "pnpm --filter @pm/mobile start",
    "seed": "pnpm --filter @pm/api seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "mongodb-memory-server"
    ]
  }
}
