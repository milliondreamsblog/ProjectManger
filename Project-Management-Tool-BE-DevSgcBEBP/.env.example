# ============================================================
#  SGC Project Management Tool — Backend environment variables
#  Copy this file to ".env" and fill in your own values.
#  NEVER commit the real .env file (it is gitignored).
# ============================================================

# --- Core (required) ---
# MongoDB connection string (create a free MongoDB Atlas M0 cluster)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/SGC?retryWrites=true&w=majority
# Secret used to sign JWTs — use a long random string
JWT_SECRET=replace-with-a-long-random-secret
PORT=5001
# URL of the deployed frontend (used for OAuth redirects / links).
# This origin is also auto-added to the CORS allow-list.
FRONTEND_URL=http://localhost:5174
# Extra CORS origins (comma-separated). localhost:5173/5174 are always allowed.
# Example: https://your-app.vercel.app,https://yourdomain.com
CORS_ORIGINS=

# --- File uploads: Cloudinary (recommended, free tier) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- File uploads: AWS S3 (optional alternative to Cloudinary) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_REGION=ap-south-1

# --- Email / SMTP (optional — leave blank to disable email sending) ---
EMAIL_USERS=
EMAIL_PASSWORD=
SMTP_USER=
SMTP_PASS=

# --- Google OAuth login (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Calendar API (optional, separate credentials) ---
GOOGLE_CLIENT_ID_C=
GOOGLE_CLIENT_SECRET_C=

# --- Pusher real-time notifications (optional, free tier) ---
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2
# Pusher Beams web push (optional, currently disabled in code)
PUSHER_BEAMS_INSTANCE_ID=
PUSHER_BEAMS_SECRET_KEY=

# --- Zoho Books client sync (optional — mocked/seeded in portfolio build) ---
ZOHO_ORG_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:5001/api/zoho/callback
