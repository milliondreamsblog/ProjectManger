# ============================================================
#  SGC Project Management Tool — Frontend environment variables
#  Copy this file to ".env" and fill in your own values.
#  Vite only exposes variables prefixed with VITE_ to the app.
#  NEVER commit the real .env file (it is gitignored).
# ============================================================

# Base URL of the backend API (no trailing slash)
VITE_API_BASE_URL=http://localhost:5001

# Google OAuth login + Drive picker (optional)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# Pusher real-time notifications (optional) — use the PUBLIC key only
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=ap2
