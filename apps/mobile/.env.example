# Expo public env — copy to .env. Only EXPO_PUBLIC_* vars are exposed to the app.

# Backend API base URL (no trailing slash).
# - iOS simulator / web: http://localhost:5001
# - Physical device (Expo Go): use your machine's LAN IP, e.g. http://192.168.1.50:5001
# - Production: your deployed Render URL, e.g. https://projectmanager-api.onrender.com
EXPO_PUBLIC_API_URL=http://localhost:5001
